@page
@model IndexModel
@{
    ViewData["Title"] = "Рецепты";
}

<h2>@ViewData["Title"]</h2>
<hr />

<div class="table-responsive">
    <table class="table table-striped recipe">
        <thead>
            <tr>
                <th>Recipe</th>
                <th>TimeToCook</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var recipe in Model.Recipes)
            {
                <tr>
                    <td class="align-middle">@recipe.Name</td>
                    <td class="align-middle">@recipe.TimeToCook</td>
                    <td class="align-middle">
                        <a asp-page="Recipes/View" asp-route-id="@recipe.Id" class="btn btn-primary">
                            Просмотреть
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<a asp-page="Recipes/Create" class="btn btn-success">Создать рецепт +</a>
