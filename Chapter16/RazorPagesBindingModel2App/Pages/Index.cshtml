@page "{handler?}"
@model IndexModel
@{
    ViewData["Title"] = "Edit Product";
}

<h1>Нажмите «Submit», чтобы отправить модель.</h1>
<form asp-page-handler="EditProduct">
    <div class="form-group">
        <label asp-for="Product.Id"></label>
        <input class="form-control" asp-for="Product.Id" />
    </div>
    <div class="form-group">
        <label asp-for="Product.Name"></label>
        <input class="form-control" asp-for="Product.Name" />
    </div>
    <div class="form-group">
        <label asp-for="Product.SellPrice"></label>
        <input class="form-control" asp-for="Product.SellPrice" />
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>

<h1>Нажмите «Submit», чтобы отправить форму с двумя моделями.</h1>
<p>
    Привязка к нескольким аргументам встречается редко, поэтому вам нужно выполнить больше работы для правильной
    привязки модели, и вы не можете просто использовать помощников тегов.
</p>
<form asp-page-handler="EditTwoProducts">
    <div class="form-group">
        <label>Product 1 Id</label>
        <input class="form-control" name="product1.@nameof(Model.Product.Id)" />
    </div>
    <div class="form-group">
        <label>Product 1 Name</label>
        <input class="form-control" name="product1.@nameof(Model.Product.Name)" />
    </div>
    <div class="form-group">
        <label>Product 1 SellPrice</label>
        <input class="form-control" name="product1.@nameof(Model.Product.SellPrice)" />
    </div>
    <div class="form-group">
        <label>Product 2 Id</label>
        <input class="form-control" name="product2.@nameof(Model.Product.Id)" />
    </div>
    <div class="form-group">
        <label>Product 2 Name</label>
        <input class="form-control" name="product2.@nameof(Model.Product.Name)" />
    </div>
    <div class="form-group">
        <label>Product 2 SellPrice</label>
        <input class="form-control" name="product2.@nameof(Model.Product.SellPrice)" />
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>
