@page "{username}/{state}"
@model RazorPagesBindingModelApp.Pages.Tasks.DevTasksModel
@{
    ViewData["Title"] = "Dev tasks";
}

<div class="row">
    <div class="col-md-12">
        <h2>Dev tasks</h2>
    </div>
    <div class="col-md-6">
        <dl class="dl-horizontal">
            <dt>Username: @Model.ViewModel.Username</dt>
            <dt>State: @Model.ViewModel.State</dt>
        </dl>
    </div>
    <div class="col-md-6">
        <ul>
            @foreach (var item in Model.ViewModel.DevTasks)
            {
                <li>@item.Id - @item.Title</li>
            }
        </ul>
    </div>
</div>