@page
@model IndexModel
@{
    ViewData["Title"] = "All tasks";
}
<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-12">
        <h2>Tasks: </h2>
        <ul>
            @foreach (var houseTask in Model.HouseTasks)
            {
                <li>
                    <a asp-page="SimpleView" asp-route-id="@houseTask.Id">
                        Simple view
                    </a>
                    -
                    <a asp-page="HouseTasksView" asp-route-id="@houseTask.Id">
                        @string.Join(", ", houseTask.HouseTaskSet)
                    </a>
                </li>
            }
        </ul>
    </div>
</div>
