@page "{id}"
@model RazorPagesRenderingHtml3App.Pages.SimpleViewModel

<h1>Задачи для выполнения @Model.HouseTask!.Id:</h1>
<ul>
    @for (int i = 0; i < Model.HouseTask.HouseTaskSet.Length; i++)
    {
        string? subTask = Model.HouseTask.HouseTaskSet[i];
        <li>@i - @subTask</li>
    }
</ul>
