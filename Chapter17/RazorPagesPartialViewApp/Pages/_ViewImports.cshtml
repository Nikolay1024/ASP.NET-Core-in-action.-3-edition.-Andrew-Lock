@* Файл _ViewImports.cshtml служит для установки общих параметров для всех представлений приложения. *@

@* Директива @using подключает пространство имен, делая доступными в коде всех представлений
типы из этого пространства имен. *@
@using RazorPagesPartialViewApp
@* Директива @namespace устанавливает пространство имён, в котором будут созданы все представления. *@
@namespace RazorPagesPartialViewApp.Pages
@* Директива @addTagHelper делает доступными тег-хелперы в всех представлениях. *@
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
