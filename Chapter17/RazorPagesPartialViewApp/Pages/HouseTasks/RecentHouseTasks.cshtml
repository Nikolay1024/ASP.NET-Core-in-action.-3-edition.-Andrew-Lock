@page
@model RazorPagesPartialViewApp.Pages.HouseTasks.RecentHouseTasksModel
@{
    ViewData["Title"] = "Recent HouseTasks";
}

<h2>Последние @Model.RecentHouseTasksToDisplay задач по дому:</h2>

<div class="row">
    <div class="col-md-12">
        @foreach (var houseTask in Model.RecentHouseTasks)
        {
            @* Используем тег-хелпер <partial/> для отрисовки частичного представления _HouseTaskPartialView,
            передавая модель HouseTask. *@
            <partial name="_HouseTaskPartialView" model="houseTask" />
            <a asp-page="HouseTaskView" asp-route-id="@houseTask.Id">Просмотреть задачу по дому</a>
        }
    </div>
</div>
