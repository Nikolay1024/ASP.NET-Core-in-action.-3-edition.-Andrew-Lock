{
  "Logging": {
    // Правила, которые будут применяться, если для поставщика логирования нет подходящих правил ниже.
    "LogLevel": {
      "Default": "Error",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    // Правила, которые будут применяться к поставщику логирования Seq.
    "Seq": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    // Правила, которые будут применяться к поставщику логирования в файл.
    "File": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    // Правила, которые будут применяться к поставщику логирования в отладку.
    "Debug": {
      "LogLevel": {
        "Default": "Debug",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    // Правила, которые будут применяться к поставщику логирования в консоль.
    "Console": {
      "LogLevel": {
        "Default": "Trace",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
