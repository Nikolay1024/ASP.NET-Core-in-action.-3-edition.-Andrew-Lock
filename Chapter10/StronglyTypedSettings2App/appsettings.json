{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Общие настройки, связанные с отображением приложения.
  "AppDisplaySettings": {
    "Title": "Acme Store Locator",
    "ShowCopyright": true
  },

  // Настройки карты по умолчанию, связанные с разделом поиска магазинов в приложении.
  "MapSettings": {
    "DefaultZoomLevel": 6,
    "DefaultLocation": {
      "Latitude": 50.500,
      "Longitude": -4.000
    }
  }
}
