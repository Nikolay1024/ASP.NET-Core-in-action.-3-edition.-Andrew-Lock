{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Общие настройки, связанные с отображением приложения.
  "AppDisplaySettings": {
    "Title": "Acme Store Locator",
    "ShowCopyright": true
  },

  // Настройки карты по умолчанию, связанные с разделом поиска магазинов в приложении.
  "MapSettings": {
    "DefaultZoomLevel": 6,
    "DefaultLocation": {
      "Latitude": 50.500,
      "Longitude": -4.000
    }
  },

  // Настройки карты, связанные с расположением магазинов в городах.
  "Stores": [
    {
      "Name": "London",
      "Location": {
        "Latitude": 51.5074,
        "Longitude": -0.1278
      }
    },
    {
      "Name": "Birmingham",
      "Location": {
        "Latitude": 52.4862,
        "Longitude": -1.8904
      }
    },
    {
      "Name": "Exeter",
      "Location": {
        "Latitude": 50.7184,
        "Longitude": -3.5339
      }
    }
  ]
}
